# ========================================
# 🔐 TWITCH CONFIGURATION
# ========================================
# Obtén estas credenciales desde:
# https://dev.twitch.tv/console/apps

TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Username del canal (NO ID)
# Ejemplo: ibai, xqc, luishongo
TWITCH_USER_LOGIN=your_channel_name_here


# ========================================
# 📁 OUTPUT CONFIGURATION
# ========================================
# Carpeta donde se guardarán los clips
OUTPUT_DIR=out


# ========================================
# 📱 VERTICAL LAYOUT CONFIG (9:16)
# ========================================
# Ajusta el recorte del layout vertical

VERTICAL_TOP_H=620
VERTICAL_GAP_H=24
VERTICAL_BOT_H=1276

# Posición y tamaño del facecam
VERTICAL_FACE_X=0
VERTICAL_FACE_Y=8
VERTICAL_FACE_W=620
VERTICAL_FACE_H=390